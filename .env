# Asterism test-app-xpub — Development Environment
#
# Web app that exercises asterism-xpub: user login, Trezor onboarding
# (XPUB capture via Trezor Connect), and a federation-membership homepage.

# =============================================================================
# Web server
# =============================================================================
APP_HOST=127.0.0.1
APP_PORT=8090
# 64-byte (hex) secret for signing session cookies. Replace before deploying
# anything that resembles production.
APP_SESSION_SECRET=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff

RUST_LOG=test_app_xpub=debug,asterism=debug,tower_http=info,sqlx=warn

# =============================================================================
# PostgreSQL
# =============================================================================
DATABASE_URL=postgres://asterism:asterism@host.docker.internal:5432/asterism_xpub

# =============================================================================
# Bitcoin / federation defaults
# =============================================================================
# We run against the local regtest node defined in ../btc_regtest/docker-compose.yml.
# Switching to testnet/signet/mainnet requires adjusting BITCOIN_RPC_PORT (and
# typically pointing at a different node).

# BIP-48 derivation paths, one per federation scheme. testnet/regtest both
# use coin_type 1, account 0; script-type 2 is P2WSH multisig and script-type
# 3 is Taproot multisig (BIP-386). Values MUST be double-quoted: dotenvy
# parses bare apostrophes as single-quote delimiters, which would silently
# strip the hardened markers and ship `m/48/1/0/X` to Trezor.
APP_FED_DERIVATION_PATH_P2WSH="m/48'/1'/0'/2'"
APP_FED_DERIVATION_PATH_TAPROOT="m/48'/1'/0'/3'"
# Legacy single-path variable, still honoured as the P2WSH default if
# APP_FED_DERIVATION_PATH_P2WSH is not set. Prefer the per-scheme variables
# above for new deployments.
APP_FED_DERIVATION_PATH="m/48'/1'/0'/2'"

# =============================================================================
# Bitcoin Core RPC (regtest)
# =============================================================================
BITCOIN_RPC_USER=signetbtc
BITCOIN_RPC_PASSWORD=signetbtcpass
BITCOIN_RPC_HOST=host.docker.internal
BITCOIN_RPC_PORT=38332
BITCOIN_NETWORK=signet

ELEMENTS_RPC_USER=elements
ELEMENTS_RPC_PASSWORD=elementspass
ELEMENTS_RPC_HOST=127.0.0.1
ELEMENTS_RPC_PORT=18884
ELEMENTS_NETWORK=elementsregtest
ELEMENTS_WALLET_NAME=default
# Esplora HTTP endpoint LWK uses to sync Liquid federations. Optional:
# leave unset to disable Liquid sync (the UI will surface "no indexer
# configured"). For mainnet point this at https://blockstream.info/liquid/api,
# for Liquid testnet at https://blockstream.info/liquidtestnet/api, and for
# the local elementsd-regtest stack at the local Esplora indexer. We do NOT
# drive `Wollet` from `elementsd` RPC directly — LWK requires an
# Electrum/Esplora-shaped client.
#ELEMENTS_ESPLORA_URL=http://127.0.0.1:3003
# Name passed to Bitcoin Core's "loadwallet" RPC. Currently informational —
# our BDK wallet is descriptor-based and does not rely on a Core wallet — but
# kept here for future RPCs that require a wallet context.
BITCOIN_WALLET_NAME=asterism-xpub-regtest

# =============================================================================
# Trezor Connect
# =============================================================================
# Coin token recognized by Trezor Connect:
#   "btc"   -> mainnet
#   "test"  -> testnet (and regtest, since the xpub material is identical)
TREZOR_COIN=test
# Manifest values surfaced by @trezor/connect (purely cosmetic in dev).
TREZOR_MANIFEST_EMAIL=dev@asterism.local
TREZOR_MANIFEST_APP_URL=http://127.0.0.1:8090

# =============================================================================
# Jade
# =============================================================================
# Allow the browser to OVERWRITE an existing same-name Jade multisig
# registration. Truthy values: 1/true/yes/on (case-insensitive). Missing or
# anything else => false.
#
# SAFE DEFAULT (false / missing): the Jade driver refuses to silently replace a
# registration, so a hostile host cannot swap in an attacker-cosigner
# descriptor. Enabled here (true) for local dev, where re-registering a
# federation under the same name during testing is expected. Leave this UNSET
# (or false) in any non-dev environment.
ALLOW_JADE_OVERWRITE=true
